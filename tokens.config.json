{
  "$schema": "./scripts/tokens.config.schema.json",
  "sourceRoot": "src/design-tokens",
  "header": "Generated by Style Dictionary — do not edit (run `npm run tokens:build`, config in tokens.config.json).",
  "manifest": true,
  "collections": [
    {
      "id": "breakpoint",
      "prefix": "breakpoint",
      "preserveCase": true,
      "files": ["breakpoint.json"],
      "modeAxes": []
    },
    {
      "id": "metrics",
      "prefix": "",
      "preserveCase": false,
      "files": ["metrics.json"],
      "modeAxes": []
    },
    {
      "id": "primitives",
      "prefix": "primitives",
      "preserveCase": false,
      "files": ["primitives.json"],
      "modeAxes": [
        {
          "name": "brand",
          "source": "nested",
          "strategy": "selectors",
          "default": "modeBrand1",
          "map": {
            "modeBrand1": ":root",
            "modeBrand2": "[data-brand='brand2'], .brand2",
            "modeBrand3": "[data-brand='brand3'], .brand3"
          }
        }
      ]
    },
    {
      "id": "responsive",
      "prefix": "",
      "preserveCase": false,
      "files": ["responsive.json"],
      "modeAxes": [
        {
          "name": "viewport",
          "source": "nested",
          "strategy": "media",
          "default": "modeMobile",
          "map": {
            "modeMobile": ":root"
          }
        }
      ]
    },
    {
      "id": "semantics",
      "prefix": "",
      "preserveCase": false,
      "files": ["semantics.json"],
      "modeAxes": [
        {
          "name": "theme",
          "source": "nested",
          "strategy": "selectors",
          "default": "modeLight",
          "map": {
            "modeDark": "[data-theme='dark'], .dark",
            "modeLight": ":root, [data-theme='light'], .light"
          }
        }
      ]
    },
    {
      "id": "transitions",
      "prefix": "",
      "preserveCase": false,
      "files": ["transitions.json"],
      "modeAxes": []
    },
    {
      "id": "typography",
      "prefix": "",
      "preserveCase": false,
      "files": ["typography.json"],
      "modeAxes": []
    },
    {
      "id": "styles",
      "prefix": "",
      "preserveCase": false,
      "files": ["styles.json"],
      "modeAxes": []
    }
  ],
  "outputs": [
    {
      "id": "css",
      "format": "css-vars",
      "destination": "src/styles/src/generated",
      "collections": ["metrics", "primitives", "responsive", "semantics", "transitions", "typography"]
    },
    {
      "id": "scss",
      "format": "scss-vars",
      "destination": "src/styles/src/generated",
      "collections": ["breakpoint"]
    },
    {
      "id": "styles",
      "format": "composite-styles",
      "destination": "src/styles/src/generated",
      "collections": ["styles"]
    }
  ]
}
